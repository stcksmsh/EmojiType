{
  "name": "emojitype",
  "version": "2.10",
  "description": "Type emojis in any text field by replacing :keyword: with emojis.",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/copy-build.js",
    "lint": "eslint src --ext .js",
    "lint:fix": "eslint src --ext .js --fix",
    "format": "prettier --write \"src/**/*.{js,json,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,json,html,css}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "vitest": "^2.0.0"
  }
}
